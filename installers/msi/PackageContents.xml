<?xml version="1.0" encoding="utf-8"?>
<!--
  AutoCAD Application Bundle Manifest
  
  This file tells AutoCAD to automatically load DeepBimAutoCADMCP on startup.
  It is installed to:
    C:\Program Files\Autodesk\ApplicationPlugins\DeepBimAutoCADMCP.bundle\PackageContents.xml
  
  AutoCAD discovers bundles in:
    - C:\Program Files\Autodesk\ApplicationPlugins\  (all users, this installer)
    - %APPDATA%\Autodesk\ApplicationPlugins\         (current user)
  
  SeriesMin="R22.0" = AutoCAD 2018.
  SeriesMax is omitted so generated 2025/2026/2027 MSI files are discoverable.
  Note: this only controls AutoCAD autoloader discovery. The plugin DLL runtime
  must still match the target AutoCAD .NET runtime/SDK.
-->
<ApplicationPackage SchemaVersion="1.0"
                    AppVersion="1.0.0"
                    ProductCode="{B3C4D5E6-F7A8-9012-BCDE-F01234567891}"
                    Name="DeepBim AutoCAD MCP Plugin"
                    Description="AutoCAD MCP Plugin — AI Integration via Model Context Protocol"
                    Author="DeepBim">

  <CompanyDetails Name="DeepBim" URL="" Email="" />

  <Components Description="DeepBim AutoCAD MCP Plugin">
    <ComponentEntry AppName="DeepBimAutoCADMCP"
                    Version="1.0.0"
                    AppDescription="DeepBim AutoCAD MCP Plugin"
                    AppType=".Net"
                    ModuleName="./Contents/AutoCADMCPPlugin.dll"
                    LoadOnAutoCADStartup="True"
                    LoadOnCommandInvocation="True">
      <RuntimeRequirements OS="Win64"
                           Platform="AutoCAD*"
                           SeriesMin="R22.0"
                           SupportPath="./Contents" />
      <Commands GroupName="DeepBimMCP">
        <Command Global="MCPSTART" Local="MCPSTART" />
        <Command Global="MCPSTOP" Local="MCPSTOP" />
        <Command Global="MCPSTATUS" Local="MCPSTATUS" />
        <Command Global="MCPSETTINGS" Local="MCPSETTINGS" />
      </Commands>
    </ComponentEntry>
  </Components>

</ApplicationPackage>
